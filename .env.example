# Bedrock short-term API key (fornecida pelo avaliador).
# boto3 ≥ 1.39 lê esta variável automaticamente — não precisa de AWS_ACCESS_KEY_ID/SECRET.
AWS_BEARER_TOKEN_BEDROCK=

# Região onde a chave foi emitida.
AWS_REGION=us-east-1

# Modelo Claude no Bedrock. Use cross-region inference profile ("us." prefix) se disponível.
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# URL base da API mockada (rodando localmente).
API_BASE_URL=http://127.0.0.1:8080
